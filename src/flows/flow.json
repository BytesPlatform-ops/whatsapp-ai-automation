{
  "version": "7.0",
  "data_api_version": "3.0",
  "routing_model": {
    "COMMON": ["SALON", "DETAILS"],
    "SALON": ["SERVICE"],
    "SERVICE": ["FINISH"],
    "DETAILS": ["FINISH"],
    "FINISH": []
  },
  "screens": [
    {
      "id": "COMMON",
      "title": "About your business",
      "data": {
        "common_title": { "type": "string", "__example__": "About your business" },
        "l_name": { "type": "string", "__example__": "Business name" },
        "l_email": { "type": "string", "__example__": "Your email" },
        "l_industry": { "type": "string", "__example__": "What kind of business?" },
        "industry_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [{ "id": "salon", "title": "Salon & Beauty" }, { "id": "general", "title": "Other" }]
        },
        "l_next": { "type": "string", "__example__": "Next" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "f1",
            "children": [
              { "type": "TextInput", "name": "business_name", "label": "${data.l_name}", "input-type": "text", "required": true },
              { "type": "TextInput", "name": "email", "input-type": "email", "label": "${data.l_email}", "required": true },
              { "type": "Dropdown", "name": "industry", "label": "${data.l_industry}", "data-source": "${data.industry_options}", "required": true },
              {
                "type": "Footer",
                "label": "${data.l_next}",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": { "business_name": "${form.business_name}", "email": "${form.email}", "industry": "${form.industry}" }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "SALON",
      "title": "${data.salon_title}",
      "data": {
        "salon_title": { "type": "string", "__example__": "Salon details" },
        "l_currency": { "type": "string", "__example__": "Currency" },
        "currency_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [{ "id": "USD", "title": "USD ($)" }, { "id": "EUR", "title": "EUR (€)" }]
        },
        "l_booking": { "type": "string", "__example__": "Booking" },
        "booking_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [{ "id": "build", "title": "Build booking into my site" }, { "id": "own", "title": "I use my own tool" }]
        },
        "l_hours": { "type": "string", "__example__": "Opening hours" },
        "hours_helper": { "type": "string", "__example__": "e.g. Tue-Sat 9-7" },
        "l_next": { "type": "string", "__example__": "Next" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "f_salon",
            "children": [
              { "type": "Dropdown", "name": "currency", "label": "${data.l_currency}", "data-source": "${data.currency_options}", "required": true },
              { "type": "RadioButtonsGroup", "name": "booking", "label": "${data.l_booking}", "data-source": "${data.booking_options}", "required": true },
              { "type": "TextInput", "name": "hours", "input-type": "text", "label": "${data.l_hours}", "helper-text": "${data.hours_helper}", "required": false },
              {
                "type": "Footer",
                "label": "${data.l_next}",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": { "currency": "${form.currency}", "booking": "${form.booking}", "hours": "${form.hours}" }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "SERVICE",
      "title": "${data.service_title}",
      "data": {
        "service_title": { "type": "string", "__example__": "Your services" },
        "added_summary": { "type": "string", "__example__": "Added so far: Haircut" },
        "added_visible": { "type": "boolean", "__example__": false },
        "l_sname": { "type": "string", "__example__": "Service name" },
        "l_sprice": { "type": "string", "__example__": "Price" },
        "sprice_helper": { "type": "string", "__example__": "e.g. 25 or $25" },
        "l_sdur": { "type": "string", "__example__": "Duration" },
        "sdur_helper": { "type": "string", "__example__": "e.g. 30 min" },
        "l_addmore": { "type": "string", "__example__": "Add more?" },
        "addmore_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [{ "id": "add", "title": "Add another service" }, { "id": "done", "title": "That's all" }]
        },
        "l_continue": { "type": "string", "__example__": "Continue" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextBody", "text": "${data.added_summary}", "visible": "${data.added_visible}" },
          {
            "type": "Form",
            "name": "f_service",
            "children": [
              { "type": "TextInput", "name": "sname", "input-type": "text", "label": "${data.l_sname}", "required": true },
              { "type": "TextInput", "name": "sprice", "input-type": "text", "label": "${data.l_sprice}", "helper-text": "${data.sprice_helper}", "required": false },
              { "type": "TextInput", "name": "sdur", "input-type": "text", "label": "${data.l_sdur}", "helper-text": "${data.sdur_helper}", "required": false },
              { "type": "RadioButtonsGroup", "name": "addmore", "label": "${data.l_addmore}", "data-source": "${data.addmore_options}", "required": false },
              {
                "type": "Footer",
                "label": "${data.l_continue}",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": { "sname": "${form.sname}", "sprice": "${form.sprice}", "sdur": "${form.sdur}", "addmore": "${form.addmore}" }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "DETAILS",
      "title": "${data.details_title}",
      "data": {
        "details_title": { "type": "string", "__example__": "A few details" },
        "f1_label": { "type": "string", "__example__": "Tell us about your work" },
        "f1_helper": { "type": "string", "__example__": "" },
        "f2_label": { "type": "string", "__example__": "More" },
        "f2_helper": { "type": "string", "__example__": "" },
        "f2_visible": { "type": "boolean", "__example__": true },
        "l_next": { "type": "string", "__example__": "Next" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "f_details",
            "children": [
              { "type": "TextArea", "name": "f1", "label": "${data.f1_label}", "helper-text": "${data.f1_helper}", "required": false },
              { "type": "TextArea", "name": "f2", "label": "${data.f2_label}", "helper-text": "${data.f2_helper}", "required": false, "visible": "${data.f2_visible}" },
              {
                "type": "Footer",
                "label": "${data.l_next}",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": { "f1": "${form.f1}", "f2": "${form.f2}" }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "FINISH",
      "title": "${data.finish_title}",
      "terminal": true,
      "data": {
        "finish_title": { "type": "string", "__example__": "Contact details" },
        "l_cemail": { "type": "string", "__example__": "Contact email" },
        "l_cphone": { "type": "string", "__example__": "Phone" },
        "l_caddress": { "type": "string", "__example__": "Address" },
        "build": { "type": "string", "__example__": "Build my site" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "f3",
            "children": [
              { "type": "TextInput", "name": "c_email", "input-type": "email", "label": "${data.l_cemail}", "required": false },
              { "type": "TextInput", "name": "c_phone", "input-type": "phone", "label": "${data.l_cphone}", "required": false },
              { "type": "TextArea", "name": "c_address", "label": "${data.l_caddress}", "required": false },
              {
                "type": "Footer",
                "label": "${data.build}",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": { "c_email": "${form.c_email}", "c_phone": "${form.c_phone}", "c_address": "${form.c_address}" }
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
