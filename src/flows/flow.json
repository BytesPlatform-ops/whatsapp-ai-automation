{
  "version": "7.0",
  "data_api_version": "3.0",
  "routing_model": {
    "COMMON": ["SALON", "DETAILS", "AGENT"],
    "SALON": ["SERVICE"],
    "SERVICE": ["FINISH"],
    "AGENT": ["LISTING"],
    "LISTING": ["FINISH"],
    "DETAILS": ["FINISH", "HVAC_SERVICE"],
    "HVAC_SERVICE": ["FINISH"],
    "FINISH": []
  },
  "screens": [
    {
      "id": "COMMON",
      "title": "${data.common_title}",
      "data": {
        "common_title": { "type": "string", "__example__": "About your business" },
        "l_name": { "type": "string", "__example__": "Business name" },
        "l_business_desc": { "type": "string", "__example__": "What does your business do?" },
        "business_desc_helper": { "type": "string", "__example__": "A sentence or two — what you offer and who for." },
        "l_industry": { "type": "string", "__example__": "What kind of business?" },
        "industry_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [{ "id": "salon", "title": "Salon & Beauty" }, { "id": "general", "title": "Other" }]
        },
        "l_logo": { "type": "string", "__example__": "Your logo" },
        "l_logo_desc": { "type": "string", "__example__": "Upload it and I'll clean up the background. Skip if you don't have one." },
        "l_next": { "type": "string", "__example__": "Next" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "f1",
            "children": [
              { "type": "TextInput", "name": "business_name", "label": "${data.l_name}", "input-type": "text", "required": true },
              { "type": "TextArea", "name": "business_description", "label": "${data.l_business_desc}", "helper-text": "${data.business_desc_helper}", "required": false },
              { "type": "Dropdown", "name": "industry", "label": "${data.l_industry}", "data-source": "${data.industry_options}", "required": true },
              {
                "type": "PhotoPicker",
                "name": "logo",
                "label": "${data.l_logo}",
                "description": "${data.l_logo_desc}",
                "photo-source": "camera_gallery",
                "min-uploaded-photos": 0,
                "max-uploaded-photos": 1
              },
              {
                "type": "Footer",
                "label": "${data.l_next}",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": { "business_name": "${form.business_name}", "business_description": "${form.business_description}", "industry": "${form.industry}", "logo": "${form.logo}" }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "SALON",
      "title": "${data.salon_title}",
      "data": {
        "salon_title": { "type": "string", "__example__": "Salon details" },
        "l_currency": { "type": "string", "__example__": "Currency" },
        "currency_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [{ "id": "USD", "title": "USD ($)" }, { "id": "EUR", "title": "EUR (€)" }]
        },
        "l_booking_heading": { "type": "string", "__example__": "Online booking" },
        "l_booking": { "type": "string", "__example__": "How should clients book?" },
        "booking_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [{ "id": "build", "title": "Build online booking into my site" }, { "id": "own", "title": "I use my own tool (Fresha, Booksy…)" }]
        },
        "l_booking_link": { "type": "string", "__example__": "Your booking link" },
        "booking_link_helper": { "type": "string", "__example__": "Paste your Fresha, Booksy or Calendly link — or skip and add it later." },
        "l_hours": { "type": "string", "__example__": "Opening hours" },
        "hours_helper": { "type": "string", "__example__": "e.g. Tue-Sat 9-7" },
        "l_next": { "type": "string", "__example__": "Next" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "f_salon",
            "children": [
              { "type": "Dropdown", "name": "currency", "label": "${data.l_currency}", "data-source": "${data.currency_options}", "required": true },
              { "type": "TextSubheading", "text": "${data.l_booking_heading}" },
              { "type": "RadioButtonsGroup", "name": "booking", "label": "${data.l_booking}", "data-source": "${data.booking_options}", "required": true },
              {
                "type": "If",
                "condition": "${form.booking} == 'own'",
                "then": [
                  { "type": "TextInput", "name": "booking_link", "input-type": "text", "label": "${data.l_booking_link}", "helper-text": "${data.booking_link_helper}", "required": false }
                ]
              },
              { "type": "TextInput", "name": "hours", "input-type": "text", "label": "${data.l_hours}", "helper-text": "${data.hours_helper}", "required": false },
              {
                "type": "Footer",
                "label": "${data.l_next}",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": { "currency": "${form.currency}", "booking": "${form.booking}", "booking_link": "${form.booking_link}", "hours": "${form.hours}" }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "SERVICE",
      "title": "${data.service_title}",
      "data": {
        "service_title": { "type": "string", "__example__": "Your services" },
        "added_summary": { "type": "string", "__example__": "Added so far: Haircut" },
        "added_visible": { "type": "boolean", "__example__": false },
        "l_sname": { "type": "string", "__example__": "Service name" },
        "sname_helper": { "type": "string", "__example__": "e.g. Haircut" },
        "l_sprice": { "type": "string", "__example__": "Price" },
        "sprice_helper": { "type": "string", "__example__": "e.g. 25" },
        "l_sdur": { "type": "string", "__example__": "Duration" },
        "sdur_helper": { "type": "string", "__example__": "e.g. 30 min" },
        "l_addmore": { "type": "string", "__example__": "Add more?" },
        "addmore_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [{ "id": "add", "title": "Add another service" }, { "id": "done", "title": "That's all" }]
        },
        "l_continue": { "type": "string", "__example__": "Continue" },
        "service_init": {
          "type": "object",
          "properties": { "sname": { "type": "string" }, "sprice": { "type": "string" }, "sdur": { "type": "string" } },
          "__example__": { "sname": "", "sprice": "", "sdur": "" }
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextBody", "text": "${data.added_summary}", "visible": "${data.added_visible}" },
          {
            "type": "Form",
            "name": "f_service",
            "init-values": "${data.service_init}",
            "children": [
              { "type": "TextInput", "name": "sname", "input-type": "text", "label": "${data.l_sname}", "helper-text": "${data.sname_helper}", "required": true },
              { "type": "TextInput", "name": "sprice", "input-type": "number", "label": "${data.l_sprice}", "helper-text": "${data.sprice_helper}", "required": false },
              { "type": "TextInput", "name": "sdur", "input-type": "text", "label": "${data.l_sdur}", "helper-text": "${data.sdur_helper}", "required": false },
              { "type": "RadioButtonsGroup", "name": "addmore", "label": "${data.l_addmore}", "data-source": "${data.addmore_options}", "required": false },
              {
                "type": "Footer",
                "label": "${data.l_continue}",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": { "sname": "${form.sname}", "sprice": "${form.sprice}", "sdur": "${form.sdur}", "addmore": "${form.addmore}" }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "DETAILS",
      "title": "${data.details_title}",
      "data": {
        "details_title": { "type": "string", "__example__": "A few details" },
        "l_currency": { "type": "string", "__example__": "Currency" },
        "currency_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [{ "id": "USD", "title": "USD ($)" }, { "id": "EUR", "title": "EUR (€)" }]
        },
        "currency_visible": { "type": "boolean", "__example__": false },
        "f1_label": { "type": "string", "__example__": "Tell us about your work" },
        "f1_helper": { "type": "string", "__example__": "" },
        "f2_label": { "type": "string", "__example__": "More" },
        "f2_helper": { "type": "string", "__example__": "" },
        "f2_visible": { "type": "boolean", "__example__": true },
        "l_next": { "type": "string", "__example__": "Next" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "f_details",
            "children": [
              { "type": "Dropdown", "name": "currency", "label": "${data.l_currency}", "data-source": "${data.currency_options}", "visible": "${data.currency_visible}", "required": "${data.currency_visible}" },
              { "type": "TextArea", "name": "f1", "label": "${data.f1_label}", "helper-text": "${data.f1_helper}", "required": false },
              { "type": "TextArea", "name": "f2", "label": "${data.f2_label}", "helper-text": "${data.f2_helper}", "required": false, "visible": "${data.f2_visible}" },
              {
                "type": "Footer",
                "label": "${data.l_next}",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": { "currency": "${form.currency}", "f1": "${form.f1}", "f2": "${form.f2}" }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "HVAC_SERVICE",
      "title": "${data.hsvc_title}",
      "data": {
        "hsvc_title": { "type": "string", "__example__": "Services you offer" },
        "added_summary": { "type": "string", "__example__": "Added so far: AC repair" },
        "added_visible": { "type": "boolean", "__example__": false },
        "l_hsvc": { "type": "string", "__example__": "Service" },
        "hsvc_helper": { "type": "string", "__example__": "e.g. AC repair" },
        "l_addmore": { "type": "string", "__example__": "Add more?" },
        "addmore_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [{ "id": "add", "title": "Add another service" }, { "id": "done", "title": "That's all" }]
        },
        "l_continue": { "type": "string", "__example__": "Continue" },
        "hsvc_init": {
          "type": "object",
          "properties": { "sname": { "type": "string" } },
          "__example__": { "sname": "" }
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextBody", "text": "${data.added_summary}", "visible": "${data.added_visible}" },
          {
            "type": "Form",
            "name": "f_hsvc",
            "init-values": "${data.hsvc_init}",
            "children": [
              { "type": "TextInput", "name": "sname", "input-type": "text", "label": "${data.l_hsvc}", "helper-text": "${data.hsvc_helper}", "required": true },
              { "type": "RadioButtonsGroup", "name": "addmore", "label": "${data.l_addmore}", "data-source": "${data.addmore_options}", "required": false },
              {
                "type": "Footer",
                "label": "${data.l_continue}",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": { "sname": "${form.sname}", "addmore": "${form.addmore}" }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "AGENT",
      "title": "${data.agent_title}",
      "data": {
        "agent_title": { "type": "string", "__example__": "Agent details" },
        "l_currency": { "type": "string", "__example__": "Currency" },
        "currency_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [{ "id": "USD", "title": "USD ($)" }, { "id": "EUR", "title": "EUR (€)" }]
        },
        "l_brokerage": { "type": "string", "__example__": "Brokerage" },
        "brokerage_helper": { "type": "string", "__example__": "Your brokerage. Leave blank if you work solo." },
        "l_years": { "type": "string", "__example__": "Years in real estate" },
        "years_helper": { "type": "string", "__example__": "e.g. 8" },
        "l_designations": { "type": "string", "__example__": "Designations" },
        "designations_helper": { "type": "string", "__example__": "e.g. CRS, ABR, CCIM. Or leave blank." },
        "l_next": { "type": "string", "__example__": "Next" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "f_agent",
            "children": [
              { "type": "Dropdown", "name": "currency", "label": "${data.l_currency}", "data-source": "${data.currency_options}", "required": true },
              { "type": "TextInput", "name": "brokerage", "input-type": "text", "label": "${data.l_brokerage}", "helper-text": "${data.brokerage_helper}", "required": true },
              { "type": "TextInput", "name": "years", "input-type": "number", "label": "${data.l_years}", "helper-text": "${data.years_helper}", "required": false },
              { "type": "TextInput", "name": "designations", "input-type": "text", "label": "${data.l_designations}", "helper-text": "${data.designations_helper}", "required": false },
              {
                "type": "Footer",
                "label": "${data.l_next}",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": { "currency": "${form.currency}", "brokerage": "${form.brokerage}", "years": "${form.years}", "designations": "${form.designations}" }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "LISTING",
      "title": "${data.listing_title}",
      "data": {
        "listing_title": { "type": "string", "__example__": "Your listings" },
        "added_summary": { "type": "string", "__example__": "Added so far: 45 Elm St" },
        "added_visible": { "type": "boolean", "__example__": false },
        "l_address": { "type": "string", "__example__": "Address" },
        "address_helper": { "type": "string", "__example__": "e.g. 45 Elm St" },
        "l_lprice": { "type": "string", "__example__": "Price" },
        "lprice_helper": { "type": "string", "__example__": "e.g. 525000" },
        "l_status": { "type": "string", "__example__": "Status" },
        "status_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [{ "id": "For Sale", "title": "For Sale" }, { "id": "Sold", "title": "Sold" }]
        },
        "l_beds": { "type": "string", "__example__": "Beds" },
        "beds_helper": { "type": "string", "__example__": "e.g. 3" },
        "l_baths": { "type": "string", "__example__": "Baths" },
        "baths_helper": { "type": "string", "__example__": "e.g. 2" },
        "l_sqft": { "type": "string", "__example__": "Sqft" },
        "sqft_helper": { "type": "string", "__example__": "e.g. 1800" },
        "l_neighborhood": { "type": "string", "__example__": "Neighborhood" },
        "neighborhood_helper": { "type": "string", "__example__": "e.g. Westlake. Or leave blank." },
        "l_lphoto": { "type": "string", "__example__": "Listing photo" },
        "l_lphoto_desc": { "type": "string", "__example__": "Add a photo of this property, or skip for a stock image." },
        "l_addmore": { "type": "string", "__example__": "Add more?" },
        "addmore_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [{ "id": "add", "title": "Add another listing" }, { "id": "done", "title": "That's all" }]
        },
        "l_continue": { "type": "string", "__example__": "Continue" },
        "listing_init": {
          "type": "object",
          "properties": { "address": { "type": "string" }, "price": { "type": "string" }, "beds": { "type": "string" }, "baths": { "type": "string" }, "sqft": { "type": "string" }, "neighborhood": { "type": "string" } },
          "__example__": { "address": "", "price": "", "beds": "", "baths": "", "sqft": "", "neighborhood": "" }
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextBody", "text": "${data.added_summary}", "visible": "${data.added_visible}" },
          {
            "type": "Form",
            "name": "f_listing",
            "init-values": "${data.listing_init}",
            "children": [
              { "type": "TextInput", "name": "address", "input-type": "text", "label": "${data.l_address}", "helper-text": "${data.address_helper}", "required": true },
              { "type": "TextInput", "name": "price", "input-type": "number", "label": "${data.l_lprice}", "helper-text": "${data.lprice_helper}", "required": true },
              { "type": "Dropdown", "name": "status", "label": "${data.l_status}", "data-source": "${data.status_options}", "required": true },
              { "type": "TextInput", "name": "beds", "input-type": "number", "label": "${data.l_beds}", "helper-text": "${data.beds_helper}", "required": false },
              { "type": "TextInput", "name": "baths", "input-type": "number", "label": "${data.l_baths}", "helper-text": "${data.baths_helper}", "required": false },
              { "type": "TextInput", "name": "sqft", "input-type": "number", "label": "${data.l_sqft}", "helper-text": "${data.sqft_helper}", "required": true },
              { "type": "TextInput", "name": "neighborhood", "input-type": "text", "label": "${data.l_neighborhood}", "helper-text": "${data.neighborhood_helper}", "required": false },
              {
                "type": "PhotoPicker",
                "name": "photo",
                "label": "${data.l_lphoto}",
                "description": "${data.l_lphoto_desc}",
                "photo-source": "camera_gallery",
                "min-uploaded-photos": 0,
                "max-uploaded-photos": 1
              },
              { "type": "RadioButtonsGroup", "name": "addmore", "label": "${data.l_addmore}", "data-source": "${data.addmore_options}", "required": false },
              {
                "type": "Footer",
                "label": "${data.l_continue}",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": { "address": "${form.address}", "price": "${form.price}", "status": "${form.status}", "beds": "${form.beds}", "baths": "${form.baths}", "sqft": "${form.sqft}", "neighborhood": "${form.neighborhood}", "photo": "${form.photo}", "addmore": "${form.addmore}" }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "FINISH",
      "title": "${data.finish_title}",
      "terminal": true,
      "data": {
        "finish_title": { "type": "string", "__example__": "Contact details" },
        "l_cemail": { "type": "string", "__example__": "Contact email" },
        "l_ccode": { "type": "string", "__example__": "Country code" },
        "country_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [{ "id": "+1", "title": "United States (+1)" }, { "id": "+44", "title": "UK (+44)" }]
        },
        "l_cphone": { "type": "string", "__example__": "Phone number" },
        "l_caddress": { "type": "string", "__example__": "Address" },
        "build": { "type": "string", "__example__": "Build my site" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "f3",
            "children": [
              { "type": "TextInput", "name": "c_email", "input-type": "email", "label": "${data.l_cemail}", "required": true },
              { "type": "Dropdown", "name": "c_code", "label": "${data.l_ccode}", "data-source": "${data.country_options}", "required": true },
              { "type": "TextInput", "name": "c_phone", "input-type": "phone", "label": "${data.l_cphone}", "required": true },
              { "type": "TextArea", "name": "c_address", "label": "${data.l_caddress}", "required": false },
              {
                "type": "Footer",
                "label": "${data.build}",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": { "c_email": "${form.c_email}", "c_code": "${form.c_code}", "c_phone": "${form.c_phone}", "c_address": "${form.c_address}" }
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
