# Where each "Join Pixie" waitlist lead is emailed (via FormSubmit — no API key).
# Optional: falls back to bytesuite@bytesplatform.com if unset.
# ONE-TIME: the first lead to a new address triggers a FormSubmit confirmation
# email — click its activation link once, then all future leads deliver.
WAITLIST_LEAD_EMAIL=bytesuite@bytesplatform.com

# ── Supabase Auth (dashboard login/register) ────────────────────────────────
# Get these from your Supabase project → Settings → API. The auth middleware is
# a no-op until both are set, so the marketing site keeps working without them.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
