# Where each "Join Pixie" waitlist lead is emailed (via FormSubmit — no API key).
# Optional: falls back to bytesuite@bytesplatform.com if unset.
# ONE-TIME: the first lead to a new address triggers a FormSubmit confirmation
# email — click its activation link once, then all future leads deliver.
WAITLIST_LEAD_EMAIL=bytesuite@bytesplatform.com

# ── Waitlist email (Resend — resend.com) ────────────────────────────────────
# FormSubmit 403-blocks Vercel's server IPs, so waitlist leads send via Resend.
# Required: an API key from resend.com. With the default onboarding@resend.dev
# sender, Resend's test mode delivers ONLY to your Resend account's own email
# (fine if that's bytesuite@bytesplatform.com). For other recipients / volume,
# verify a domain in Resend and set RESEND_FROM.
RESEND_API_KEY=re_your_api_key
# RESEND_FROM="Pixie <noreply@bytesplatform.com>"

# ── Supabase (waitlist storage + admin panel auth) ──────────────────────────
# Project URL + keys from Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Server-only — NEVER prefix with NEXT_PUBLIC. Used by the API route + admin
# panel to read/write waitlist_responses (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Who may sign in to /admin-panel (comma-separated emails). These must be
# Supabase Auth users. Falls back to bytesuite@bytesplatform.com if unset.
ADMIN_EMAILS=bytesuite@bytesplatform.com
